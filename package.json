{
  "name": "mgifford-repo-catalog",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Curated and auto-updated catalog for mgifford repositories",
  "type": "module",
  "scripts": {
    "sync:repos": "node scripts/sync-repos.mjs",
    "build:data": "node scripts/build-site-data.mjs",
    "validate:data": "node scripts/validate-generated-data.mjs",
    "validate:curation": "node scripts/validate-curation.mjs",
    "sync:all": "npm run sync:repos && npm run build:data",
    "screenshot:pages": "node scripts/capture-pages-screenshots.mjs",
    "start": "npx serve .",
    "test": "node --test",
    "test:a11y": "node --test tests/accessibility.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "playwright": "^1.53.2",
    "serve": "^14.2.4"
  }
}
